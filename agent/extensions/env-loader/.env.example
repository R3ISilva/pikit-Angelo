# Place this file at ~/.pi/agent/configs/.env — gitignored, never committed

# GitHub — generate at github.com/settings/tokens (classic, repo scope)
GITHUB_TOKEN=ghp_your-token-here

# Slack — from api.slack.com/apps → Basic Information → App Credentials
SLACK_CLIENT_ID=your-client-id-here
SLACK_CLIENT_SECRET=your-client-secret-here

# Web access extension — Google Search grounding via Gemini
GEMINI_API_KEY=AIza-your-key-here

# Sentry and Atlassian — no tokens needed, mcp-remote handles OAuth automatically
